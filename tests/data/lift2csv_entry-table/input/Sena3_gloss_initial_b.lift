<entry dateCreated="2005-06-23T16:30:31Z" dateModified="2011-08-04T18:22:25Z" id="kanwa_066cbf82-7cd9-4cf8-a4c7-c62a84da72ea" guid="066cbf82-7cd9-4cf8-a4c7-c62a84da72ea">
<lexical-unit>
<form lang="seh"><text>kanwa</text></form>
</lexical-unit>
<trait  name="morph-type" value="root"/>
<field type="Plural">
<form lang="seh"><text>makanwa</text></form>
</field>
<sense id="17a07bfd-3e70-4daf-ad3f-47d7c57d70ee">
<grammatical-info value="Nome">
<trait name="inflection-feature" value="{Infl}[NounAgr:[genro:5/6]]"/>
</grammatical-info>
<gloss lang="en"><text>mouth inside</text></gloss>
<gloss lang="pt"><text>boca interior</text></gloss>
<example>
<form lang="seh"><text>mpaka nyama ifikire pa n'kanwa mwace (Sulo 023)</text></form>
<translation type="Free translation">
<form lang="en"><text>until meat arrives in mouth his</text></form>
<form lang="pt"><text>até a carne chega na boca d'ele</text></form>
</translation>
</example>
<example source="Nyazeze">
<form lang="seh"><text>khanwa mbee na kubira</text></form>
<translation type="Free translation">
<form lang="en"><text>always crying</text></form>
<form lang="pt"><text>lit."boca aberta por chorar" id."sempre chora"</text></form>
</translation>
<note type="reference">
<form lang="en"><text>Nyazeze</text></form>
</note>
</example>
<note type="grammar">
<form lang="en"><text>perhaps n'- kanwa detro de boca?</text></form>
</note>
<note type="phonology">
<form lang="en"><text>alt: khanwa |probably dialectal difference</text></form>
</note>
<note type="semantics">
<form lang="en"><text>mulomo is mouth, kanwa is inside the mouth</text></form>
</note>
</sense>
</entry>
